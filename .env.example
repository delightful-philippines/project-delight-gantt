# ============================================================
# Project Delight Gantt — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your actual values.
# This file is safe to commit. .env is NOT.
# ============================================================

# ----------------------------------------------------------
# Supabase — Project API
# Found in: Supabase Dashboard → Project Settings → API
# ----------------------------------------------------------
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_SERVICE_ROLE_KEY=

# ----------------------------------------------------------
# Supabase — Direct Database Connection (PostgreSQL)
# Found in: Supabase Dashboard → Project Settings → Database
# ----------------------------------------------------------
VITE_SUPABASE_DB_HOST=
VITE_SUPABASE_DB_PORT=5432
VITE_SUPABASE_DB_DATABASE=postgres
VITE_SUPABASE_DB_USERNAME=postgres
VITE_SUPABASE_DB_PASSWORD=
VITE_SUPABASE_DB_SSLMODE=require

# ----------------------------------------------------------
# Microsoft Entra ID (Azure AD) - Single Tenant Authentication
# ----------------------------------------------------------
# Found in: Azure Portal -> Microsoft Entra ID -> App registrations -> Your App
VITE_AZURE_CLIENT_ID=
VITE_AZURE_TENANT_ID=
AZURE_CLIENT_SECRET=
AZURE_REDIRECT_URI=http://localhost:5173/api/auth/callback

# ----------------------------------------------------------
# Server Configuration
# ----------------------------------------------------------
SESSION_SECRET=
# FRONTEND_URL: Used for CORS and email invitation links
# Development: http://localhost:5173
# Production: https://gantt.delightful.ph
FRONTEND_URL=http://localhost:5173

# NOTE: Secure cookies are now auto-detected based on X-Forwarded-Proto header
# No need for ENABLE_SECURE_COOKIE environment variable

# ----------------------------------------------------------
# AI Integration
# ----------------------------------------------------------
# Google Gemini API key used for the "AI Support" auto-generation feature
GEMINI_API_KEY=AIzaSyAXhNw_5Ef5njG767tq0NTg4RzAEHIOFYo
